# Copia a .env en la raíz del repo (local) o configura las mismas variables en Render.
ENVIRONMENT=development
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/db_trabajo
SECRET_KEY=genera-un-secreto-largo-y-aleatorio

# Producción (Render): origen HTTPS del front en Vercel, separado por comas si hay varios.
CORS_ORIGINS=https://tu-proyecto.vercel.app
REFRESH_COOKIE_SECURE=true
REFRESH_COOKIE_SAMESITE=none

# Opcional: correo, Cloudinary, zona horaria
BUSINESS_TIMEZONE=America/Bogota
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Ferragro
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
